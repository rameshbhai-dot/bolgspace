<%- include('partials/header') %>

<div class="page-header">
  <h1><%= query ? 'Results for "' + query + '"' : 'Search' %></h1>
  <form class="search-form-large" action="/search" method="GET">
    <div class="search-input-wrapper">
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="text" name="q" value="<%= query %>" placeholder="Search articles..." class="search-input" autocomplete="off">
    </div>
  </form>
</div>

<div class="container">
  <div class="content-with-sidebar">
    <div class="main-content">
      <% if (posts.length > 0) { %>
        <p class="results-count"><%= posts.length %> article<%= posts.length !== 1 ? 's' : '' %> found</p>
        <div class="posts-grid">
          <% posts.forEach(function(post) { %>
            <%- include('partials/post-card', { post: post }) %>
          <% }) %>
        </div>
      <% } else if (query) { %>
        <div class="empty-state">
          <h3>No results found</h3>
          <p>Try different keywords or browse our categories.</p>
        </div>
      <% } else { %>
        <div class="empty-state">
          <h3>Search for articles</h3>
          <p>Type something above to find articles.</p>
        </div>
      <% } %>
    </div>
    <%- include('partials/sidebar', { ads: ads }) %>
  </div>
</div>

<%- include('partials/footer') %>
