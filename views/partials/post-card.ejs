<article class="post-card">
  <a href="/blog/<%= post.slug %>">
    <% if (post.featured_image) { %>
      <div class="post-card-image" style="background-image: url('<%= post.featured_image %>')"></div>
    <% } else { %>
      <div class="post-card-image post-card-image-placeholder">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="placeholder-icon"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
      </div>
    <% } %>
  </a>
  <div class="post-card-body">
    <% if (post.category_name) { %>
      <a href="/category/<%= post.category_slug %>" class="category-badge"><%= post.category_name %></a>
    <% } %>
    <h3 class="post-card-title"><a href="/blog/<%= post.slug %>"><%= post.title %></a></h3>
    <p class="post-card-excerpt"><%= post.excerpt %></p>
    <div class="post-card-meta">
      <span class="author"><%= post.display_name || post.username %></span>
      <span class="dot">&middot;</span>
      <span class="date"><%= new Date(post.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
    </div>
  </div>
</article>
