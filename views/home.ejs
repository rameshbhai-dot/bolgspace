<%- include('partials/header') %>

<% if (typeof sponsoredPosts !== 'undefined' && sponsoredPosts && sponsoredPosts.length > 0) { %>
  <!-- Sponsored Blogs Block -->
  <section class="container" style="margin-top: var(--space-8); margin-bottom: var(--space-4);">
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--color-primary); padding-bottom: var(--space-2); margin-bottom: var(--space-6);">
      <h2 style="font-size: var(--font-size-xl); margin: 0; color: var(--color-primary);">Featured & Sponsored</h2>
      <a href="/sponsor" style="font-size: var(--font-size-sm); color: var(--color-text-secondary); text-decoration: underline;">Sponsor Your Post</a>
    </div>
    <div class="posts-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
      <% sponsoredPosts.forEach(function(post) { %>
        <%- include('partials/post-card', { post: post }) %>
      <% }) %>
    </div>
  </section>
<% } else { %>
  <!-- Promote Your Story CTA -->
  <section class="container" style="margin-top: var(--space-8); text-align: right;">
      <a href="/sponsor" style="font-size: var(--font-size-sm); color: var(--color-text-secondary); text-decoration: underline;">Sponsor Your Post</a>
  </section>
<% } %>

<% if (posts.length > 0) { %>
  <!-- Hero Section -->
  <section class="hero">
    <a href="/blog/<%= posts[0].slug %>" class="hero-card">
      <div class="hero-card-image" style="background-image: url('<%= posts[0].featured_image || '' %>')"></div>
      <div class="hero-card-overlay"></div>
      <div class="hero-card-content">
        <% if (posts[0].category_name) { %>
          <span class="category-badge"><%= posts[0].category_name %></span>
        <% } %>
        <h1><%= posts[0].title %></h1>
        <p><%= posts[0].excerpt %></p>
        <div class="hero-card-meta">
          <span><%= posts[0].display_name || posts[0].username %></span>
          <span class="dot">&middot;</span>
          <span><%= new Date(posts[0].created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
        </div>
      </div>
    </a>
  </section>
<% } %>

<div class="container">
  <!-- Homepage Hero Ad -->
  <% const heroAds = ads.filter(a => a.placement === 'homepage_hero'); %>
  <% if (heroAds.length > 0) { %>
    <div style="margin-bottom: var(--space-10); text-align: center;">
      <span style="display: block; font-size: 0.65rem; color: var(--color-text-muted); text-transform: uppercase; margin-bottom: 4px;">Advertisement</span>
      <% heroAds.forEach(ad => { %>
        <div style="margin-bottom: var(--space-4);">
          <% if (ad.html_code) { %>
            <%- ad.html_code %>
          <% } else if (ad.image_url) { %>
            <a href="<%= ad.link_url || '#' %>" target="_blank">
              <img src="<%= ad.image_url %>" alt="<%= ad.title || 'Ad' %>" style="max-width: 100%; height: auto; border-radius: var(--radius-md);">
            </a>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>

  <div class="section-header">
    <h2 class="section-title">Latest Articles</h2>
  </div>

  <div class="content-with-sidebar">
    <div class="main-content">
      <div class="posts-grid">
        <% const remainingPosts = posts.slice(1); %>
        <% if (remainingPosts.length > 0) { %>
          <% remainingPosts.forEach(function(post) { %>
            <%- include('partials/post-card', { post: post }) %>
          <% }) %>
        <% } else if (posts.length === 0) { %>
          <div class="empty-state">
            <h3>No posts yet</h3>
            <p>Be the first to publish a story!</p>
            <a href="/auth/signup" class="btn btn-primary">Get Started</a>
          </div>
        <% } %>
      </div>
    </div>

    <%- include('partials/sidebar', { ads: ads }) %>
  </div>
</div>

<%- include('partials/footer') %>
