<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/editor.css">

<div class="dashboard-container">
  <div class="dashboard-header">
    <h1>My Posts</h1>
    <a href="/dashboard/new" class="btn btn-primary">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      New Post
    </a>
  </div>

  <% if (posts.length === 0) { %>
    <div class="empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-muted); margin-bottom: 1rem;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
      <h3>No posts yet</h3>
      <p>Start writing your first blog post today.</p>
      <a href="/dashboard/new" class="btn btn-primary" style="margin-top: 1rem;">Write Your First Post</a>
    </div>
  <% } else { %>
    <table class="posts-table">
      <thead>
        <tr>
          <th>Title</th>
          <th>Category</th>
          <th>Status</th>
          <th>Views</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% posts.forEach(function(post) { %>
          <tr>
            <td><a href="/blog/<%= post.slug %>" style="color: var(--color-primary); font-weight: 500;"><%= post.title %></a></td>
            <td><%= post.category_name || '—' %></td>
            <td>
              <span class="status-badge status-<%= post.status %>"><%= post.status %></span>
            </td>
            <td><%= post.views %></td>
            <td><%= new Date(post.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></td>
            <td>
              <div class="actions">
                <a href="/dashboard/edit/<%= post.id %>" class="btn btn-outline btn-icon">Edit</a>
                <form method="POST" action="/dashboard/delete/<%= post.id %>" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this post?')">
                  <button type="submit" class="btn btn-danger btn-icon">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<%- include('../partials/footer') %>
