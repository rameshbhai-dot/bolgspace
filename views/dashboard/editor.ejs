<%- include('../partials/header') %>
<link rel="stylesheet" href="https://cdn.quilljs.com/1.3.7/quill.snow.css">
<link rel="stylesheet" href="/css/editor.css">

<div class="editor-layout">
  <div class="dashboard-header">
    <h1><%= post ? 'Edit Post' : 'Create New Post' %></h1>
    <a href="/dashboard" class="btn btn-ghost">← Back to Dashboard</a>
  </div>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form id="postForm" method="POST" action="<%= post ? '/dashboard/edit/' + post.id : '/dashboard/new' %>" enctype="multipart/form-data">
    <input type="text" id="postTitle" name="title" class="editor-title-input" placeholder="Post title..." value="<%= post ? post.title : '' %>" required>

    <div class="editor-body">
      <div class="editor-main">
        <div id="editor"></div>
        <textarea name="content" id="contentField" style="display:none;"><%= post ? post.content : '' %></textarea>
        <input type="hidden" id="existingContent" value="<%- post ? post.content.replace(/"/g, '&quot;') : '' %>">
      </div>

      <div class="editor-sidebar">
        <div class="editor-sidebar-card">
          <h3>Publish</h3>
          <div class="form-group">
            <div class="radio-group">
              <label class="radio-label">
                <input type="radio" name="status" value="published" <%= (!post || post.status === 'published') ? 'checked' : '' %>>
                Published
              </label>
              <label class="radio-label">
                <input type="radio" name="status" value="draft" <%= (post && post.status === 'draft') ? 'checked' : '' %>>
                Draft
              </label>
            </div>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%; justify-content: center;">
            <%= post ? 'Update Post' : 'Publish Post' %>
          </button>
        </div>

        <div class="editor-sidebar-card">
          <h3>Category</h3>
          <div class="form-group">
            <select name="category_id" class="form-input">
              <option value="">Select category</option>
              <% categories.forEach(function(cat) { %>
                <option value="<%= cat.id %>" <%= (post && post.category_id == cat.id) ? 'selected' : '' %>><%= cat.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="editor-sidebar-card">
          <h3>Tags</h3>
          <div class="form-group">
            <input type="text" name="tags" class="form-input" placeholder="e.g. javascript, web dev" value="<%= typeof postTags !== 'undefined' ? postTags : '' %>">
            <small style="color: var(--color-text-muted); font-size: 0.75rem;">Separate with commas</small>
          </div>
        </div>

        <div class="editor-sidebar-card">
          <h3>Featured Image</h3>
          <div class="form-group">
            <input type="file" id="featuredImage" name="featured_image" class="form-input form-input-file" accept="image/*">
            <div id="imagePreview">
              <% if (post && post.featured_image) { %>
                <img src="<%= post.featured_image %>" class="image-preview" alt="Current featured image">
              <% } else { %>
                <div class="image-preview-placeholder">No image selected</div>
              <% } %>
            </div>
          </div>
        </div>

        <div class="editor-sidebar-card">
          <h3>Excerpt</h3>
          <div class="form-group">
            <textarea name="excerpt" class="form-input" rows="3" placeholder="Brief summary (auto-generated if empty)"><%= post ? post.excerpt : '' %></textarea>
          </div>
        </div>
      </div>
    </div>
  </form>
</div>

<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script src="/js/editor.js"></script>
<%- include('../partials/footer') %>
