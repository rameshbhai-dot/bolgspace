<%- include('partials/header') %>

<div class="auth-wrapper">
  <div class="auth-card" style="text-align: center;">
    <h1 style="font-size: var(--font-size-5xl); color: var(--color-primary); margin-bottom: var(--space-4);">404</h1>
    <h2 style="margin-bottom: var(--space-4);"><%= typeof message !== 'undefined' ? message : 'Page not found' %></h2>
    <p class="subtitle">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="btn btn-primary" style="margin-top: var(--space-6);">Back to Home</a>
  </div>
</div>

<%- include('partials/footer') %>
