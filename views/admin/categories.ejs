<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/admin.css">

<div class="admin-layout">
  <nav class="admin-nav">
    <div class="admin-nav-title">Admin Panel</div>
    <a href="/admin" class="admin-nav-link">Dashboard</a>
    <a href="/admin/posts" class="admin-nav-link">Posts</a>
    <a href="/admin/users" class="admin-nav-link">Users</a>
    <a href="/admin/ads" class="admin-nav-link">Ads</a>
    <a href="/admin/categories" class="admin-nav-link active">Categories</a>
  </nav>

  <div class="admin-content">
    <h1 style="margin-bottom: var(--space-8);">Manage Categories</h1>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); align-items: start;">
      <!-- Add Category Form -->
      <div class="admin-form">
        <h2>Add New Category</h2>
        <form method="POST" action="/admin/categories">
          <div class="form-group">
            <label class="form-label">Name</label>
            <input type="text" name="name" class="form-input" placeholder="Category name" required>
          </div>
          <div class="form-group">
            <label class="form-label">Description</label>
            <textarea name="description" class="form-input" rows="3" placeholder="Brief description"></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Add Category</button>
        </form>
      </div>

      <!-- Existing Categories -->
      <div>
        <h2 style="font-size: var(--font-size-xl); font-weight: 600; margin-bottom: var(--space-6);">Existing Categories</h2>
        <% categories.forEach(function(cat) { %>
          <div style="background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg); padding: var(--space-5); margin-bottom: var(--space-4); display: flex; justify-content: space-between; align-items: center;">
            <div>
              <strong><%= cat.name %></strong>
              <% if (cat.description) { %>
                <p style="font-size: var(--font-size-sm); color: var(--color-text-secondary); margin-top: var(--space-1);"><%= cat.description %></p>
              <% } %>
            </div>
            <form method="POST" action="/admin/categories/delete/<%= cat.id %>" style="display:inline;" onsubmit="return confirm('Delete this category? Posts in this category will be uncategorized.')">
              <button type="submit" class="btn btn-danger btn-icon">Delete</button>
            </form>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
