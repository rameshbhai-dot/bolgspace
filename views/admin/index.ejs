<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/admin.css">

<div class="admin-layout">
  <nav class="admin-nav">
    <div class="admin-nav-title">Admin Panel</div>
    <a href="/admin" class="admin-nav-link active">Dashboard</a>
    <a href="/admin/posts" class="admin-nav-link">Posts</a>
    <a href="/admin/users" class="admin-nav-link">Users</a>
    <a href="/admin/ads" class="admin-nav-link">Ads</a>
    <a href="/admin/categories" class="admin-nav-link">Categories</a>
  </nav>

  <div class="admin-content">
    <h1 style="margin-bottom: var(--space-8);">Dashboard Overview</h1>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-card-icon purple">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
        </div>
        <h3><%= stats.totalPosts %></h3>
        <p>Total Posts</p>
      </div>
      <div class="stat-card">
        <div class="stat-card-icon blue">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
        </div>
        <h3><%= stats.totalUsers %></h3>
        <p>Total Users</p>
      </div>
      <div class="stat-card">
        <div class="stat-card-icon green">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <h3><%= stats.publishedPosts %></h3>
        <p>Published</p>
      </div>
      <div class="stat-card">
        <div class="stat-card-icon orange">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
        </div>
        <h3><%= stats.totalViews %></h3>
        <p>Total Views</p>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
