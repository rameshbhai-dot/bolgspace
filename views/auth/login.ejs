<%- include('../partials/header') %>

<div class="auth-wrapper">
  <div class="auth-card">
    <h1>Welcome back</h1>
    <p class="subtitle">Log in to your account to start writing.</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/auth/login">
      <div class="form-group">
        <label class="form-label" for="email">Email</label>
        <input type="email" id="email" name="email" class="form-input" placeholder="you@example.com" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label" for="password">Password</label>
        <input type="password" id="password" name="password" class="form-input" placeholder="Enter your password" required>
      </div>
      <button type="submit" class="btn btn-primary btn-lg" style="width:100%; justify-content: center;">Log In</button>
    </form>

    <p class="auth-footer">Don't have an account? <a href="/auth/signup">Sign up</a></p>
  </div>
</div>

<%- include('../partials/footer') %>
